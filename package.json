{
  "name": "tawjih-pro",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.js",
  "homepage": "./",
  "author": {
    "name": "Haddadi Abderaouf",
    "email": "haddadi.abdraouf@gmail.com"
  },
  "description": "School Guidance System for Intermediate Education",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:serve": "npm run build && cross-env NODE_ENV=production electron . --prod",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "clean": "rm -rf dist release",
    "prebuild": "echo 'Starting build process...'",
    "dist": "npm run clean && npm run build && electron-builder --win nsis --x64 --publish=never",
    "test:file": "npm run build && electron . --test-file",
    "serve": "npm run electron:serve"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "dexie": "^4.0.1",
    "electron-log": "^5.4.3",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-updater": "^6.8.3",
    "javascript-obfuscator": "^4.1.0",
    "postcss": "^8.4.35",
    "rollup-plugin-javascript-obfuscator": "^1.0.4",
    "tailwindcss": "^3.4.1",
    "terser": "^5.44.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "Al-Wajeez",
        "repo": "Tawjih-Pro"
      }
    ],
    "appId": "com.tawjihpro.app",
    "productName": "Tawjih Pro",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/favicon.ico"
    ],
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "differentialPackage": false,
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico",
      "uninstallDisplayName": "Tawjih Pro",
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
